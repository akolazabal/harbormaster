# Base Sepolia RPC (the public default works)
HM_RPC_URL=https://sepolia.base.org

# Circle testnet USDC on Base Sepolia (production settles in USDC)
HM_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# wallet-cli account label / derivation account index
HM_ACCOUNT=harbormaster

# Signing adapter: mock | wallet-cli | dmk | speculos
#   mock        no device; used by the tests and the no-device dry run
#   dmk         genuine Device Management Kit over the Speculos HTTP transport (the demonstrated path)
#   speculos    on-device signing over hw-transport-node-speculos (fallback)
#   wallet-cli  Ledger Wallet CLI (production USB path)
HM_ADAPTER=mock

# Set to 0 to run the full signing flow without broadcasting (recommended for an unfunded device);
# any other value (or unset) broadcasts the signed transaction.
HM_BROADCAST=0

# Speculos automation/REST API, read by the dmk adapter and demo/device.ts.
# Host 5005 maps to the container's 5000 (macOS AirPlay occupies host port 5000).
# The APDU TCP server is on 127.0.0.1:9999.
SPECULOS_API=http://127.0.0.1:5005
